# Cloudinary Configuration
# Get these values from https://cloudinary.com/console/settings

# Your Cloudinary Cloud Name (e.g., "d1234abcd")
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Your Cloudinary API Key (for backend operations)
VITE_CLOUDINARY_API_KEY=your_api_key_here

# Your Cloudinary Upload Preset (name of the preset you created)
VITE_CLOUDINARY_UPLOAD_PRESET=geetadhya_unsigned

# Optional: Backend API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
